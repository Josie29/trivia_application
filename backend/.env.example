# Copy to .env in this directory (never commit .env).
# OpenAI: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Optional: required only for CLI (main.py), not for the FastAPI server (run.py).
# Default channel if unset: https://m.twitch.tv/neglagonave
# TWITCH_CHANNEL_URL=https://www.twitch.tv/otherchannel

# TLS (corporate proxy): see README Troubleshooting. Local debug only:
# STREAMLINK_SSL_VERIFY=false
# or: TWITCH_STREAMLINK_INSECURE_SSL=1
