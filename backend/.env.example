# Copy to .env in this directory (never commit .env).
# config.py resolves .env relative to its own location, so this file always
# loads from backend/ regardless of the working directory you start from.

# ── Twitch ────────────────────────────────────────────────────────────────────
# Required for CLI (main.py); optional for API server (run.py) — URL supplied
# per request from the browser. Default if unset: https://m.twitch.tv/neglagonave
# TWITCH_CHANNEL_URL=https://www.twitch.tv/your_channel

# ── Whisper ───────────────────────────────────────────────────────────────────
# Model size: tiny | base | small | medium | large  (larger = slower, more accurate)
# WHISPER_MODEL_SIZE=base
# Device: cpu | cuda
# WHISPER_DEVICE=cpu

# ── Audio capture ─────────────────────────────────────────────────────────────
# Sliding-window settings. Window must always be > interval.
# Overlap fed to Whisper = AUDIO_WINDOW_SECONDS - SEGMENT_INTERVAL_SECONDS.
# AUDIO_WINDOW_SECONDS=30
# SEGMENT_INTERVAL_SECONDS=15

# ── Question extraction ───────────────────────────────────────────────────────
# Set to true to enable the second LLM call that extracts structured question
# fields. Disable to test audio capture → transcription → UI without OpenAI.
# ENABLE_QUESTION_EXTRACTION=false
#
# OpenAI API key — only required when ENABLE_QUESTION_EXTRACTION=true.
# Whisper runs locally, so transcription works without this key.
# OPENAI_API_KEY=

# ── Logging ───────────────────────────────────────────────────────────────────
# LOG_LEVEL=INFO

# ── CORS ──────────────────────────────────────────────────────────────────────
# Extra allowed origins beyond localhost defaults (comma-separated, no spaces,
# https only, no trailing slash). On Render, RENDER_EXTERNAL_URL is added
# automatically; only add entries here for additional custom domains.
# CORS_ORIGINS=https://your-custom-domain.com

# ── TLS / Corporate proxy (e.g. Zscaler) ─────────────────────────────────────
# See README Troubleshooting for details.
#
# Provide a combined PEM CA bundle to override certifi (use one or the other):
# SSL_CERT_FILE=/path/to/combined-ca-bundle.pem
# REQUESTS_CA_BUNDLE=/path/to/combined-ca-bundle.pem
#
# Local debug only — disables TLS verification for Streamlink (never use in production):
# TWITCH_STREAMLINK_INSECURE_SSL=true
# STREAMLINK_SSL_VERIFY=false
